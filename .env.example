APP_NAME="CP Prompt-X"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# If the app is not at the server root, set the URL path to the `public` folder (no trailing slash).
# Example: project at http://localhost/hackathon/cp-promptx/public/
APP_BASE_PATH=/hackathon/cp-promptx/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cp_promptx
DB_USERNAME=root
DB_PASSWORD=

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_WHISPER_MODEL=whisper-1
# Use a model your API key is allowed to call (e.g. gpt-4o-mini, gpt-4.1-mini, gpt-5-mini).
OPENAI_GPT_MODEL=gpt-4o-mini

MAX_UPLOAD_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=mp3,mp4,wav,m4a,ogg,webm

SESSION_LIFETIME=120
